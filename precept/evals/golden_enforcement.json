    "kind": "pretooluse",
    "policies": [{"id": "rmrf", "lesson_id": "no-rmrf", "enforcement_tier": "hard", "hook_event": "PreToolUse", "check_kind": "single_call", "decision": "deny", "message": "Refusing rm -rf.", "match": {"tool": "Bash", "conditions": [{"field": "command", "op": "regex", "value": "\\brm -rf"}]}}],
    "call": {"tool_name": "Bash", "tool_input": {"command": "rm stale.txt"}},
    "expect": "allow"
  },
  {
    "id": "read-env-violation",
    "description": "reading a .env secret must be blocked",
    "kind": "pretooluse",
    "policies": [{"id": "env", "lesson_id": "no-secrets", "enforcement_tier": "hard", "hook_event": "PreToolUse", "check_kind": "single_call", "decision": "deny", "message": "Don't read secrets.", "match": {"tool": "Read", "conditions": [{"field": "file_path", "op": "regex", "value": "\\.env"}]}}],
    "call": {"tool_name": "Read", "tool_input": {"file_path": ".env"}},
    "expect": "block"
  },
  {
    "id": "read-source-ok",
