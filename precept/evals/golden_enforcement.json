[
  {
    "id": "npm-violation",
    "description": "agent runs npm install after the user said use pnpm",
    "kind": "pretooluse",
    "policies": [{"id": "npm", "lesson_id": "use-pnpm", "enforcement_tier": "hard", "hook_event": "PreToolUse", "check_kind": "single_call", "decision": "deny", "message": "Use pnpm, not npm.", "match": {"tool": "Bash", "conditions": [{"field": "command", "op": "regex", "value": "\\bnpm install"}]}}],
    "call": {"tool_name": "Bash", "tool_input": {"command": "npm install left-pad"}},
    "expect": "block"
  },
  {
    "id": "pnpm-compliant",
    "description": "near-miss: pnpm install must NOT be blocked by the npm rule",
    "kind": "pretooluse",
    "policies": [{"id": "npm", "lesson_id": "use-pnpm", "enforcement_tier": "hard", "hook_event": "PreToolUse", "check_kind": "single_call", "decision": "deny", "message": "Use pnpm, not npm.", "match": {"tool": "Bash", "conditions": [{"field": "command", "op": "regex", "value": "\\bnpm install"}]}}],
    "call": {"tool_name": "Bash", "tool_input": {"command": "pnpm install left-pad"}},
    "expect": "allow"
  },
  {
