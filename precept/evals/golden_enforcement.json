    "kind": "pretooluse",
    "policies": [{"id": "env", "lesson_id": "no-secrets", "enforcement_tier": "hard", "hook_event": "PreToolUse", "check_kind": "single_call", "decision": "deny", "message": "Don't read secrets.", "match": {"tool": "Read", "conditions": [{"field": "file_path", "op": "regex", "value": "\\.env"}]}}],
    "call": {"tool_name": "Read", "tool_input": {"file_path": "src/main.py"}},
    "expect": "allow"
  },
  {
    "id": "edit-lockfile-violation",
    "description": "hand-editing a lockfile must be blocked",
    "kind": "pretooluse",
    "policies": [{"id": "lock", "lesson_id": "no-lockfile-edits", "enforcement_tier": "hard", "hook_event": "PreToolUse", "check_kind": "single_call", "decision": "deny", "message": "Don't hand-edit lockfiles.", "match": {"tool": "Edit", "conditions": [{"field": "file_path", "op": "regex", "value": "(pnpm-lock|package-lock|poetry\\.lock|uv\\.lock)"}]}}],
    "call": {"tool_name": "Edit", "tool_input": {"file_path": "pnpm-lock.yaml", "old_string": "a", "new_string": "b"}},
