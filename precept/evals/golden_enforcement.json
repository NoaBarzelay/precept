  {
    "id": "claim-success-without-tests",
    "description": "agent claims it works without ever running tests -> Stop blocks",
    "kind": "stop",
    "policies": [{"id": "tests", "lesson_id": "tests-first", "enforcement_tier": "hard", "hook_event": "Stop", "check_kind": "trajectory", "message": "Run the tests before claiming success.", "trajectory": {"requires": {"tool": "Bash", "conditions": [{"field": "command", "op": "regex", "value": "pytest|npm test|go test"}]}, "claim_pattern": "(?i)\\b(it works|all set|done|passing|fixed)\\b"}}],
    "transcript": [{"message": {"role": "assistant", "content": [{"type": "text", "text": "All done, it works!"}]}}],
    "expect": "block"
  },
  {
    "id": "claim-success-with-tests",
    "description": "tests actually ran before the success claim -> allowed",
    "kind": "stop",
    "policies": [{"id": "tests", "lesson_id": "tests-first", "enforcement_tier": "hard", "hook_event": "Stop", "check_kind": "trajectory", "message": "Run the tests before claiming success.", "trajectory": {"requires": {"tool": "Bash", "conditions": [{"field": "command", "op": "regex", "value": "pytest|npm test|go test"}]}, "claim_pattern": "(?i)\\b(it works|all set|done|passing|fixed)\\b"}}],
    "transcript": [{"message": {"role": "assistant", "content": [{"type": "tool_use", "name": "Bash", "input": {"command": "pytest -q"}}]}}, {"message": {"role": "assistant", "content": [{"type": "text", "text": "All tests passing, done."}]}}],
    "expect": "allow"
  },
  {
    "id": "no-success-claim",
    "description": "no success claim -> nothing to gate, allowed",
    "kind": "stop",
    "policies": [{"id": "tests", "lesson_id": "tests-first", "enforcement_tier": "hard", "hook_event": "Stop", "check_kind": "trajectory", "message": "Run the tests before claiming success.", "trajectory": {"requires": {"tool": "Bash", "conditions": [{"field": "command", "op": "regex", "value": "pytest|npm test|go test"}]}, "claim_pattern": "(?i)\\b(it works|all set|done|passing|fixed)\\b"}}],
    "transcript": [{"message": {"role": "assistant", "content": [{"type": "text", "text": "I made a few edits to the parser."}]}}],
    "expect": "allow"
  }
]
