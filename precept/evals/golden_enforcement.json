    "policies": [{"id": "norepo-npm", "lesson_id": "use-pnpm-here", "enforcement_tier": "hard", "hook_event": "PreToolUse", "check_kind": "single_call", "decision": "deny", "message": "Use pnpm in this repo.", "scope": "repo", "scope_value": "/work/myrepo", "match": {"tool": "Bash", "conditions": [{"field": "command", "op": "regex", "value": "\\bnpm install"}]}}],
    "call": {"tool_name": "Bash", "tool_input": {"command": "npm install left-pad"}, "cwd": "/other/place"},
    "expect": "allow"
  },
  {
    "id": "global-rule-fires-everywhere",
    "description": "a global rule (no scope_value) fires regardless of cwd",
    "kind": "pretooluse",
    "policies": [{"id": "g-npm", "lesson_id": "use-pnpm", "enforcement_tier": "hard", "hook_event": "PreToolUse", "check_kind": "single_call", "decision": "deny", "message": "Use pnpm.", "scope": "global", "match": {"tool": "Bash", "conditions": [{"field": "command", "op": "regex", "value": "\\bnpm install"}]}}],
    "call": {"tool_name": "Bash", "tool_input": {"command": "npm install left-pad"}, "cwd": "/anywhere"},
