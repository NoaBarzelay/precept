    "kind": "pretooluse",
    "policies": [{"id": "rmrf", "lesson_id": "no-rmrf", "enforcement_tier": "hard", "hook_event": "PreToolUse", "check_kind": "single_call", "decision": "deny", "message": "Refusing rm -rf.", "match": {"tool": "Bash", "conditions": [{"field": "command", "op": "regex", "value": "\\brm -rf"}]}}],
    "call": {"tool_name": "Bash", "tool_input": {"command": "rm -rf /tmp/data"}},
    "expect": "block"
  },
  {
    "id": "rm-file-ok",
