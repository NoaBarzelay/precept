  },
  {
    "id": "edit-source-ok",
    "description": "editing normal source is allowed",
    "kind": "pretooluse",
    "policies": [{"id": "lock", "lesson_id": "no-lockfile-edits", "enforcement_tier": "hard", "hook_event": "PreToolUse", "check_kind": "single_call", "decision": "deny", "message": "Don't hand-edit lockfiles.", "match": {"tool": "Edit", "conditions": [{"field": "file_path", "op": "regex", "value": "(pnpm-lock|package-lock|poetry\\.lock|uv\\.lock)"}]}}],
    "call": {"tool_name": "Edit", "tool_input": {"file_path": "src/app.ts", "old_string": "a", "new_string": "b"}},
